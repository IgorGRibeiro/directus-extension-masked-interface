{
  "name": "@ribertec/directus-extension-masked-interface",
  "version": "1.1.0",
  "description": "Masked text input interface for Directus",
  "type": "module",
  "author": "@ribertec",
  "license": "GPL-3.0",
  "keywords": [
    "directus",
    "directus-extension",
    "directus-custom-interface",
    "masked-interface",
    "masked-input"
  ],
  "directus:extension": {
    "type": "interface",
    "path": "dist/index.js",
    "source": "src/index.ts",
    "host": "^10.0.0 || ^11.0.0"
  },
  "scripts": {
    "build": "directus-extension build",
    "dev": "directus-extension build --no-minify --watch"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "inputmask": "^5.0.7"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^10.0.0",
    "typescript": "^4.6.4",
    "sass": "^1.51.0"
  }
}
